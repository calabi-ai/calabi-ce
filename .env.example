# Calabi Community Edition v1.0
#
# Copy to .env:  cp .env.example .env
# Start:         docker compose up -d
# Access:        http://localhost:8080

# Gateway port
CALABI_PORT=8080

# PostgreSQL
POSTGRES_USER=calabi
POSTGRES_PASSWORD=calabi_ce_2025

# CalabiIQ BI
SUPERSET_SECRET_KEY=calabi-ce-secret-change-me-in-prod
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_LOAD_EXAMPLES=no

# CE Limits (enforced by license proxy)
CE_MAX_CATALOGUE_USERS=5
CE_MAX_CATALOGUE_ASSETS=500
